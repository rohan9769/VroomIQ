ANTHROPIC_API_KEY=sk-ant-...

# Qdrant Cloud (leave empty to use local embedded mode — no Docker needed)
# QDRANT_URL=https://abc123.us-east-1-0.aws.cloud.qdrant.io
# QDRANT_API_KEY=your-qdrant-api-key

# Comma-separated allowed CORS origins (defaults to localhost dev servers)
# ALLOWED_ORIGINS=https://your-app.ondigitalocean.app
